# Copy this file to .env and fill in your keys.
# Get keys at the URLs below — all have free tiers.

# ── PRODUCTION CONFIG ────────────────────────────────────────────────────────
# The domain where your app is hosted (e.g., https://your-app.vercel.app)
APP_URL=https://tillu-voice.vercel.app/

# CORS Allowed Origins (comma separated, or * for all)
# Best practice: set this to your production domain.
CORS_ORIGIN=*

# ── STT ──────────────────────────────────────────────────────────────────────
# Groq  — fast Whisper-large-v3  https://console.groq.com
GROQ_API_KEY=gsk_...

# Sarvam — Indian language specialist  https://sarvam.ai
SARVAM_API_KEY=...

# ── TTS ──────────────────────────────────────────────────────────────────────
# Cartesia sonic-3.5 — multilingual incl. Hindi  https://cartesia.ai
CARTESIA_API_KEY=sk_car_...

# ElevenLabs — high-quality fallback  https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
